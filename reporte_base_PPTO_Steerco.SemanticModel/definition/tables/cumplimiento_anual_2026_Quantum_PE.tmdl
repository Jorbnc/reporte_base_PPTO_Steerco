table cumplimiento_anual_2026_Quantum_PE
	lineageTag: 122e1abc-5d4b-405a-845d-4d5b960f8b84

	column Categoría
		dataType: string
		lineageTag: bc5f3786-1544-4b05-b8ef-97a1bfb8810d
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'LB BC 26'
		dataType: double
		formatString: 0.0
		lineageTag: 9a05a113-313f-4d0c-ad86-1fe2d6575d2f
		summarizeBy: sum
		sourceColumn: [LB BC 26]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'FCST 2026'
		dataType: double
		formatString: 0.0
		lineageTag: f3c4ddec-5b29-41cf-857f-24e35059bd49
		summarizeBy: sum
		sourceColumn: [FCST 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition cumplimiento_anual_2026_Quantum_PE = calculated
		mode: import
		source =
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Financiero"},
							{"Eccsa"}
						}
					)
				VAR Base2026 =
					ADDCOLUMNS(
						FILTER(
							'consulta_base',
							VAR PaisNormalizado = LOWER(TRIM(COALESCE('consulta_base'[País], "")))
							RETURN
								PaisNormalizado IN {"perú", "peru"}
									&& YEAR('consulta_base'[Mes/ Año]) = 2026
						),
						"__Categoria",
							VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
							VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
							VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
							RETURN
								SWITCH(
									TRUE(),
									SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}, "Financiero",
									SegmentoNormalizado = "retail chile"
										&& CONTAINSSTRING(ProveedorNormalizado, "kyndryl")
										&& TipoGastoNormalizado IN {"capex", "opex"}, "Eccsa",
									BLANK()
								),
						"__FCST2026",
							IF(
								MONTH('consulta_base'[Mes/ Año]) <= 4,
								'consulta_base'[2026 REAL CLP],
								'consulta_base'[2026 FCST CLP]
							)
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"LB BC 26",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										'consulta_base'[2026LB CLP]
									),
									1000000000
								),
						"FCST 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										[__FCST2026]
									),
									1000000000
								)
					)

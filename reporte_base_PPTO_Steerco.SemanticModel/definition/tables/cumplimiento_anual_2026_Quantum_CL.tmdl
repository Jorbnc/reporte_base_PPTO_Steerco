table cumplimiento_anual_2026_Quantum_CL
	lineageTag: 4025f21f-921f-489f-b47c-cc73bb2e4b83

	column Categoría
		dataType: string
		lineageTag: 0922216f-a532-48af-bd19-a7b6fff98a7a
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'LB BC 26'
		dataType: double
		formatString: 0.0
		lineageTag: f30057d0-1b58-46e1-945d-96164262578c
		summarizeBy: sum
		sourceColumn: [LB BC 26]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'FCST 2026'
		dataType: double
		formatString: 0.0
		lineageTag: d908f506-1c3b-4463-a6c2-55e84ea65494
		summarizeBy: sum
		sourceColumn: [FCST 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition cumplimiento_anual_2026_Quantum_CL = calculated
		mode: import
		source =
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Financiero"},
							{"Eccsa"}
						}
					)
				VAR Base2026 =
					ADDCOLUMNS(
						FILTER(
							'consulta_base',
							LOWER(TRIM(COALESCE('consulta_base'[País], ""))) = "chile"
								&& YEAR('consulta_base'[Mes/ Año]) = 2026
						),
						"__Categoria",
							VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
							VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
							VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
							RETURN
								SWITCH(
									TRUE(),
									SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}, "Financiero",
									SegmentoNormalizado = "retail chile"
										&& CONTAINSSTRING(ProveedorNormalizado, "kyndryl")
										&& TipoGastoNormalizado IN {"capex", "opex"}, "Eccsa",
									BLANK()
								),
						"__FCST2026",
							IF(
								MONTH('consulta_base'[Mes/ Año]) <= 4,
								'consulta_base'[2026 REAL CLP],
								'consulta_base'[2026 FCST CLP]
							)
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"LB BC 26",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										'consulta_base'[2026LB CLP]
									),
									1000000000
								),
						"FCST 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										[__FCST2026]
									),
									1000000000
								)
					)


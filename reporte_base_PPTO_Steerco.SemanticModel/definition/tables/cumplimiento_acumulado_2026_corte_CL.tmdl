table cumplimiento_acumulado_2026_corte_CL
	lineageTag: 1b5d6579-6f13-438a-940b-39a218e030ef

	column Categoría
		dataType: string
		lineageTag: 740bc830-f9bf-4cea-b282-af835a5846c4
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'PPTO 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 5d86a01a-b7b0-472b-8f09-8d938c4bdd85
		summarizeBy: sum
		sourceColumn: [PPTO 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'REAL 2026'
		dataType: double
		formatString: 0.0
		lineageTag: fcd1a67d-0b1c-4b16-8aed-8f3613096244
		summarizeBy: sum
		sourceColumn: [REAL 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition cumplimiento_acumulado_2026_corte_CL = calculated
		mode: import
		source =
				VAR MesCorteConfig = MAXX('parametros_corte', 'parametros_corte'[Mes Corte])
				VAR MesCorteGlobal = MIN(12, MAX(1, MesCorteConfig))
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Capex"},
							{"Opex"},
							{"Eccsa"}
						}
					)
				VAR BaseCorte =
					ADDCOLUMNS(
						FILTER(
							'consulta_base',
							LOWER(TRIM(COALESCE('consulta_base'[País], ""))) = "chile"
								&& YEAR('consulta_base'[Mes/ Año]) = 2026
								&& MONTH('consulta_base'[Mes/ Año]) <= MesCorteGlobal
						),
						"__Categoria",
							VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
							VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
							VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
							VAR EsBanco =
								SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}
							VAR EsEccsa =
								SegmentoNormalizado = "retail chile"
									&& CONTAINSSTRING(ProveedorNormalizado, "kyndryl")
							RETURN
								SWITCH(
									TRUE(),
									TipoGastoNormalizado = "capex" && EsBanco, "Capex",
									TipoGastoNormalizado = "opex" && EsBanco, "Opex",
									TipoGastoNormalizado IN {"capex", "opex"} && EsEccsa, "Eccsa",
									BLANK()
								)
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"PPTO 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(BaseCorte, [__Categoria] = CategoriaActual),
										'consulta_base'[PPTO 26 Aprobado CLP]
									),
									1000000000
								),
						"REAL 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(BaseCorte, [__Categoria] = CategoriaActual),
										'consulta_base'[2026 REAL CLP]
									),
									1000000000
								)
					)

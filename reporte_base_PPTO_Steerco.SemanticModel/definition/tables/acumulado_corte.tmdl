table acumulado_corte
	lineageTag: bdf2076c-ecf8-4a26-88c0-71b5b788a1fe

	column Categoría
		dataType: string
		lineageTag: 1d33f9fd-8a71-44f2-b3a0-2c311ae69892
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'PPTO 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 1e29c3aa-ab41-4eb5-a712-25b93796b315
		summarizeBy: sum
		sourceColumn: [PPTO 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'REAL 2026'
		dataType: double
		formatString: 0.0
		lineageTag: ef4c7ec2-d8fb-41d4-96c2-c7dc18f36b90
		summarizeBy: sum
		sourceColumn: [REAL 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition acumulado_corte = calculated
		mode: import
		source =
				VAR MesCorteConfig = MAXX('parametros_corte', 'parametros_corte'[Mes Corte])
				VAR MesCorteGlobal = MIN(12, MAX(1, MesCorteConfig))
				RETURN
					SELECTCOLUMNS(
						FILTER('acumulado_hasta_corte', 'acumulado_hasta_corte'[Mes Orden] = MesCorteGlobal),
						"Categoría", 'acumulado_hasta_corte'[Categoría],
						"PPTO 2026", 'acumulado_hasta_corte'[PPTO 2026],
						"REAL 2026", 'acumulado_hasta_corte'[REAL 2026]
					)

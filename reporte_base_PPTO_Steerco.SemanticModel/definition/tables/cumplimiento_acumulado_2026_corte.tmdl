table cumplimiento_acumulado_2026_corte
	lineageTag: bdf2076c-ecf8-4a26-88c0-71b5b788a1fe

	column Categoría
		dataType: string
		lineageTag: 1d33f9fd-8a71-44f2-b3a0-2c311ae69892
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'PPTO 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 1e29c3aa-ab41-4eb5-a712-25b93796b315
		summarizeBy: sum
		sourceColumn: [PPTO 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'REAL 2026'
		dataType: double
		formatString: 0.0
		lineageTag: ef4c7ec2-d8fb-41d4-96c2-c7dc18f36b90
		summarizeBy: sum
		sourceColumn: [REAL 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition cumplimiento_acumulado_2026_corte = calculated
		mode: import
		source =
				VAR MesCorteConfig = MAXX('parametros_corte', 'parametros_corte'[Mes Corte])
				VAR MesCorteGlobal = MIN(12, MAX(1, MesCorteConfig))
				VAR FechaCorte = EOMONTH(DATE(2026, MesCorteGlobal, 1), 0)
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Capex"},
							{"Opex"},
							{"Eccsa"}
						}
					)
				VAR BaseCorte =
					ADDCOLUMNS(
						FILTER(
							'consulta_base',
							YEAR('consulta_base'[Mes/ Año]) = 2026
								&& 'consulta_base'[Mes/ Año] <= FechaCorte
						),
						"__Categoria",
							VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
							VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
							VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
							VAR EsBanco =
								SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}
							VAR EsEccsa =
								SegmentoNormalizado = "retail chile"
									&& CONTAINSSTRING(ProveedorNormalizado, "kyndryl")
							RETURN
								SWITCH(
									TRUE(),
									TipoGastoNormalizado = "capex" && EsBanco, "Capex",
									TipoGastoNormalizado = "opex" && EsBanco, "Opex",
									TipoGastoNormalizado IN {"capex", "opex"} && EsEccsa, "Eccsa",
									BLANK()
								)
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"PPTO 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(BaseCorte, [__Categoria] = CategoriaActual),
										'consulta_base'[PPTO 26 Aprobado CLP]
									),
									1000000000
								),
						"REAL 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(BaseCorte, [__Categoria] = CategoriaActual),
										'consulta_base'[2026 REAL CLP]
									),
									1000000000
								)
					)

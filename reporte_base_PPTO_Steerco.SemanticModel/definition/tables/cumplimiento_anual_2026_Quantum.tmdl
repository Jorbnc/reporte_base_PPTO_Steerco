table cumplimiento_anual_2026_Quantum
	lineageTag: b9a8ef32-5143-4126-a9e7-a81fbeb3922f

	column Categoría
		dataType: string
		lineageTag: 67e9927b-ab0d-4280-9ead-a56df86283e8
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'LB BC 26'
		dataType: double
		formatString: 0.0
		lineageTag: d42fe701-87e6-4950-b56b-b4e4125e4d23
		summarizeBy: sum
		sourceColumn: [LB BC 26]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'FCST 2026'
		dataType: double
		formatString: 0.0
		lineageTag: c1440821-6cc6-475a-9914-365a01df2af9
		summarizeBy: sum
		sourceColumn: [FCST 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition cumplimiento_anual_2026_Quantum = calculated
		mode: import
		source =
				VAR MesCorteConfig = MAXX('parametros_corte', 'parametros_corte'[Mes Corte])
				VAR MesRealFcst = MIN(12, MAX(1, MesCorteConfig))
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Financiero"},
							{"Eccsa"}
						}
					)
				VAR Base2026 =
					ADDCOLUMNS(
						FILTER(
							'consulta_base',
							YEAR('consulta_base'[Mes/ Año]) = 2026
						),
						"__Categoria",
							VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
							VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
							VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
							RETURN
								SWITCH(
									TRUE(),
									SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}, "Financiero",
									SegmentoNormalizado = "retail chile"
										&& CONTAINSSTRING(ProveedorNormalizado, "kyndryl")
										&& TipoGastoNormalizado IN {"capex", "opex"}, "Eccsa",
									BLANK()
								),
						"__FCST2026",
							IF(
								MONTH('consulta_base'[Mes/ Año]) <= MesRealFcst,
								'consulta_base'[2026 REAL CLP],
								'consulta_base'[2026 FCST CLP]
							)
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"LB BC 26",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										'consulta_base'[2026LB CLP]
									),
									1000000000
								),
						"FCST 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(Base2026, [__Categoria] = CategoriaActual),
										[__FCST2026]
									),
									1000000000
								)
					)

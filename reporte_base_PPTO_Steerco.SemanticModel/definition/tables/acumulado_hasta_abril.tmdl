table acumulado_hasta_abril
	lineageTag: 9cf8404f-1817-4006-9090-644116273cf1

	column 'Mes Orden'
		dataType: int64
		formatString: 0
		lineageTag: 4454e6fd-92d8-495f-8a6b-34e9e1cc93f9
		summarizeBy: none
		sourceColumn: [Mes Orden]

		annotation SummarizationSetBy = User

	column 'Mes Corte'
		dataType: string
		lineageTag: 3c311cad-ac98-4704-b6c5-2edcf48fdae4
		summarizeBy: none
		sourceColumn: [Mes Corte]
		sortByColumn: 'Mes Orden'

		annotation SummarizationSetBy = User

	column Categoría
		dataType: string
		lineageTag: 6075d1a4-762b-4dd9-9f33-d660f0d16a7e
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'PPTO 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 467160bf-339c-4e4d-ad90-cd1df2a646f6
		summarizeBy: sum
		sourceColumn: [PPTO 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'REAL 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 620b8319-f250-41f4-8926-52bcb94ba554
		summarizeBy: sum
		sourceColumn: [REAL 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition acumulado_hasta_abril = calculated
		mode: import
		source =
				VAR Meses =
					DATATABLE(
						"Mes Orden", INTEGER,
						"Mes Corte", STRING,
						{
							{1, "Enero"},
							{2, "Febrero"},
							{3, "Marzo"},
							{4, "Abril"}
						}
					)
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Capex"},
							{"Opex"},
							{"Eccsa"}
						}
					)
				RETURN
					SELECTCOLUMNS(
						GENERATE(
							Meses,
							VAR FechaCorte = EOMONTH(DATE(2026, [Mes Orden], 1), 0)
							RETURN
								ADDCOLUMNS(
									Categorias,
									"PPTO 2026",
										VAR CategoriaActual = [Categoría]
										RETURN
											CALCULATE(
												DIVIDE(SUM('consulta_base'[PPTO 26 Aprobado CLP]), 1000000000),
												FILTER(
													'consulta_base',
													VAR EsRetailChileKyndryl =
														LOWER(TRIM(COALESCE('consulta_base'[Segmento ], ""))) = "retail chile"
															&& CONTAINSSTRING(
																LOWER(COALESCE('consulta_base'[Proveedor], "")),
																"kyndryl"
															)
													RETURN
														YEAR('consulta_base'[Mes/ Año]) = 2026
															&& 'consulta_base'[Mes/ Año] <= FechaCorte
															&& SWITCH(
																CategoriaActual,
																"Capex",
																	LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], ""))) = "capex"
																		&& NOT EsRetailChileKyndryl,
																"Opex",
																	LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], ""))) = "opex"
																		&& NOT EsRetailChileKyndryl,
																"Eccsa",
																	EsRetailChileKyndryl,
																FALSE()
															)
												)
											),
									"REAL 2026",
										VAR CategoriaActual = [Categoría]
										RETURN
											CALCULATE(
												DIVIDE(SUM('consulta_base'[2026 REAL CLP]), 1000000000),
												FILTER(
													'consulta_base',
													VAR EsRetailChileKyndryl =
														LOWER(TRIM(COALESCE('consulta_base'[Segmento ], ""))) = "retail chile"
															&& CONTAINSSTRING(
																LOWER(COALESCE('consulta_base'[Proveedor], "")),
																"kyndryl"
															)
													RETURN
														YEAR('consulta_base'[Mes/ Año]) = 2026
															&& 'consulta_base'[Mes/ Año] <= FechaCorte
															&& SWITCH(
																CategoriaActual,
																"Capex",
																	LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], ""))) = "capex"
																		&& NOT EsRetailChileKyndryl,
																"Opex",
																	LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], ""))) = "opex"
																		&& NOT EsRetailChileKyndryl,
																"Eccsa",
																	EsRetailChileKyndryl,
																FALSE()
															)
												)
											)
								)
						),
						"Mes Orden", [Mes Orden],
						"Mes Corte", [Mes Corte],
						"Categoría", [Categoría],
						"PPTO 2026", [PPTO 2026],
						"REAL 2026", [REAL 2026]
					)

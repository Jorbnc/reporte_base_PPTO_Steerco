table acumulado_corte_PE
	lineageTag: 5daea088-01a6-4f32-a133-133d2fd41b9f

	column Categoría
		dataType: string
		lineageTag: 4885588a-87d7-42f9-a1dd-1ee21dfe0d0d
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'PPTO 2026'
		dataType: double
		formatString: 0.0
		lineageTag: bf34f221-48cf-4f07-af36-97105e8ad3dc
		summarizeBy: sum
		sourceColumn: [PPTO 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'REAL 2026'
		dataType: double
		formatString: 0.0
		lineageTag: 5977cecd-29c5-4da6-a77d-762dc2688400
		summarizeBy: sum
		sourceColumn: [REAL 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition acumulado_corte_PE = calculated
		mode: import
		source =
				VAR MesCorteConfig = MAXX('parametros_corte', 'parametros_corte'[Mes Corte])
				VAR MesCorteGlobal = MIN(12, MAX(1, MesCorteConfig))
				VAR FechaCorte = EOMONTH(DATE(2026, MesCorteGlobal, 1), 0)
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Capex"},
							{"Opex"},
							{"Eccsa"}
						}
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"PPTO 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								CALCULATE(
									DIVIDE(SUM('consulta_base'[PPTO 26 Aprobado CLP]), 1000000000),
									FILTER(
										'consulta_base',
										VAR PaisNormalizado = LOWER(TRIM(COALESCE('consulta_base'[País], "")))
										VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
										VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
										VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
										VAR EsBanco =
											SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}
										VAR EsEccsa =
											SegmentoNormalizado = "retail chile"
												&& ProveedorNormalizado IN {"kyndryl spa", "kyndryl chile spa"}
										RETURN
											PaisNormalizado IN {"perú", "peru"}
												&& YEAR('consulta_base'[Mes/ Año]) = 2026
												&& 'consulta_base'[Mes/ Año] <= FechaCorte
												&& SWITCH(
													CategoriaActual,
													"Capex",
														TipoGastoNormalizado = "capex"
															&& EsBanco,
													"Opex",
														TipoGastoNormalizado = "opex"
															&& EsBanco,
													"Eccsa",
														TipoGastoNormalizado IN {"capex", "opex"}
															&& EsEccsa,
													FALSE()
												)
									)
								),
						"REAL 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								CALCULATE(
									DIVIDE(SUM('consulta_base'[2026 REAL CLP]), 1000000000),
									FILTER(
										'consulta_base',
										VAR PaisNormalizado = LOWER(TRIM(COALESCE('consulta_base'[País], "")))
										VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
										VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
										VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
										VAR EsBanco =
											SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"}
										VAR EsEccsa =
											SegmentoNormalizado = "retail chile"
												&& ProveedorNormalizado IN {"kyndryl spa", "kyndryl chile spa"}
										RETURN
											PaisNormalizado IN {"perú", "peru"}
												&& YEAR('consulta_base'[Mes/ Año]) = 2026
												&& 'consulta_base'[Mes/ Año] <= FechaCorte
												&& SWITCH(
													CategoriaActual,
													"Capex",
														TipoGastoNormalizado = "capex"
															&& EsBanco,
													"Opex",
														TipoGastoNormalizado = "opex"
															&& EsBanco,
													"Eccsa",
														TipoGastoNormalizado IN {"capex", "opex"}
															&& EsEccsa,
													FALSE()
												)
									)
								)
					)

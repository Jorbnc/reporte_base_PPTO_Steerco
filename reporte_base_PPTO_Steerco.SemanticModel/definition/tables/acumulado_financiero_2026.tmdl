table acumulado_financiero_2026
	lineageTag: b9a8ef32-5143-4126-a9e7-a81fbeb3922f

	column Categoría
		dataType: string
		lineageTag: 67e9927b-ab0d-4280-9ead-a56df86283e8
		summarizeBy: none
		sourceColumn: [Categoría]

		annotation SummarizationSetBy = User

	column 'LB BC 26'
		dataType: double
		formatString: 0.0
		lineageTag: d42fe701-87e6-4950-b56b-b4e4125e4d23
		summarizeBy: sum
		sourceColumn: [LB BC 26]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'FCST 2026'
		dataType: double
		formatString: 0.0
		lineageTag: c1440821-6cc6-475a-9914-365a01df2af9
		summarizeBy: sum
		sourceColumn: [FCST 2026]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition acumulado_financiero_2026 = calculated
		mode: import
		source =
				VAR Categorias =
					DATATABLE(
						"Categoría", STRING,
						{
							{"Financiero"},
							{"Eccsa"}
						}
					)
				RETURN
					ADDCOLUMNS(
						Categorias,
						"LB BC 26",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									CALCULATE(
										SUM('consulta_base'[2026LB CLP]),
										FILTER(
											'consulta_base',
											VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
											VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
											VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
											RETURN
												YEAR('consulta_base'[Mes/ Año]) = 2026
													&& SWITCH(
														CategoriaActual,
														"Financiero",
															SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"},
														"Eccsa",
															SegmentoNormalizado = "retail chile"
																&& ProveedorNormalizado IN {"kyndryl spa", "kyndryl chile spa"}
																&& TipoGastoNormalizado IN {"capex", "opex"},
														FALSE()
													)
										)
									),
									1000000000
								),
						"FCST 2026",
							VAR CategoriaActual = [Categoría]
							RETURN
								DIVIDE(
									SUMX(
										FILTER(
											'consulta_base',
											VAR SegmentoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Segmento ], "")))
											VAR ProveedorNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Proveedor], "")))
											VAR TipoGastoNormalizado = LOWER(TRIM(COALESCE('consulta_base'[Tipo de Gasto], "")))
											RETURN
												YEAR('consulta_base'[Mes/ Año]) = 2026
													&& SWITCH(
														CategoriaActual,
														"Financiero",
															SegmentoNormalizado IN {"banco chile", "banco perú", "banco peru"},
														"Eccsa",
															SegmentoNormalizado = "retail chile"
																&& ProveedorNormalizado IN {"kyndryl spa", "kyndryl chile spa"}
																&& TipoGastoNormalizado IN {"capex", "opex"},
														FALSE()
													)
										),
										IF(
											MONTH('consulta_base'[Mes/ Año]) <= 4,
											'consulta_base'[2026 REAL CLP],
											'consulta_base'[2026 FCST CLP]
										)
									),
									1000000000
								)
					)
